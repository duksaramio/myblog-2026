---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PromoBanner from '../components/PromoBanner.astro';
import profile from '../data/profile.json';

const posts = (await getCollection('blog', ({ data }) => {
	return import.meta.env.PROD ? !data.draft : true;
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<BaseLayout title={profile.site.title} description={profile.site.description} seo={profile.seo}>
	{profile.banner && profile.banner.show && (
		<PromoBanner
			tag={profile.banner.tag}
			text={profile.banner.text}
			linkText={profile.banner.linkText}
			linkUrl={profile.banner.linkUrl}
		/>
	)}

	<Header logo={profile.header.logo} />

	<main>
		<div class="hero-text">
			{profile.hero.paragraphs.map((paragraph) => (
				<p set:html={paragraph} />
			))}
		</div>

		{posts.length > 0 && (
			<div class="writing-section">
				<h2 class="section-title">Writing</h2>

				{allTags.length > 0 && (
					<div class="all-tags">
						{allTags.map((tag) => (
							<a href={`/tags/${tag}`} class="tag-badge">#{tag}</a>
						))}
					</div>
				)}

				<ul class="post-list">
					{posts.map((post) => {
						const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						});
						return (
							<li class="post-item">
								<time class="post-date" datetime={post.data.pubDate.toISOString()}>
									{formattedDate}
								</time>
								<div class="post-title-and-tags">
									<a href={`/blog/${post.id}`} class="post-link">
										{post.data.title}
									</a>
									{post.data.tags && post.data.tags.length > 0 && (
										<span class="post-tags">
											{post.data.tags.map((tag) => (
												<a href={`/tags/${tag}`} class="tag-link">#{tag}</a>
											))}
										</span>
									)}
								</div>
							</li>
						);
					})}
				</ul>
			</div>
		)}

		<div class="contact-us">
			<p>
				{profile.contact.label}:{' '}
				<a
					href={profile.contact.url}
					class="service-link"
					style="text-decoration: underline;"
				>
					{profile.contact.value}
				</a>
			</p>
		</div>
	</main>
</BaseLayout>

<style>
	.writing-section {
		margin-top: 32px;
		border-top: 1px solid var(--border-color, rgba(0, 0, 0, 0.08));
		padding-top: 24px;
	}

	.all-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: 24px;
		font-size: 12px;
	}

	.tag-badge {
		color: var(--text-muted);
		text-decoration: none;
		border: 1px solid var(--border-color);
		padding: 2px 8px;
		border-radius: 4px;
		background: var(--card-bg);
		transition: all 0.2s ease;
	}

	.tag-badge:hover {
		color: var(--text-color);
		border-color: var(--underline-hover);
		background: rgba(0, 0, 0, 0.06);
	}

	.post-title-and-tags {
		display: flex;
		align-items: baseline;
		gap: 12px;
		flex-wrap: wrap;
	}

	.post-tags {
		display: flex;
		gap: 8px;
		font-size: 11px;
		opacity: 0.5;
	}

	.tag-link {
		color: inherit;
		text-decoration: none;
	}

	.tag-link:hover {
		text-decoration: underline;
	}

	.section-title {
		margin-bottom: 16px;
		font-family: var(--font-serif);
		font-size: 20px;
		font-weight: 500;
	}

	.post-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.post-item {
		display: flex;
		align-items: baseline;
		gap: 16px;
	}

	.post-date {
		font-size: 12px;
		opacity: 0.5;
		flex-shrink: 0;
		width: 90px;
	}

	.post-link {
		color: inherit;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 4px;
		text-decoration-color: var(--underline-color);
		transition: text-decoration-color 0.2s ease;
	}

	.post-link:hover {
		text-decoration-color: var(--underline-hover);
	}

	@media (max-width: 768px) {
		.post-item {
			flex-direction: column;
			gap: 4px;
		}

		.post-date {
			width: auto;
		}
	}
</style>
