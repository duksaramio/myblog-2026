---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import profile from '../../data/profile.json';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => {
		return import.meta.env.PROD ? !data.draft : true;
	});
	
	// Get list of all unique tags
	const uniqueTags = [...new Set(posts.flatMap((post) => post.data.tags || []))];
	
	return uniqueTags.map((tag) => {
		const filteredPosts = posts
			.filter((post) => (post.data.tags || []).includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { tag },
			props: { posts: filteredPosts },
		};
	});
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`Posts tagged with #${tag} | ${profile.site.title}`} description={`All posts tagged with #${tag}`} seo={profile.seo}>
	<Header logo={profile.header.logo} />

	<main>
		<div class="tag-header">
			<h1 class="section-title">Posts tagged with <i>#{tag}</i></h1>
		</div>

		<ul class="post-list">
			{posts.map((post) => {
				const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				});
				return (
					<li class="post-item">
						<time class="post-date" datetime={post.data.pubDate.toISOString()}>
							{formattedDate}
						</time>
						<div class="post-title-and-tags">
							<a href={`/blog/${post.id}`} class="post-link">
								{post.data.title}
							</a>
							{post.data.tags && post.data.tags.length > 0 && (
								<span class="post-tags">
									{post.data.tags.map((t) => (
										<a href={`/tags/${t}`} class={`tag-link ${t === tag ? 'active' : ''}`}>#{t}</a>
									))}
								</span>
							)}
						</div>
					</li>
				);
			})}
		</ul>

		<div class="back-home">
			<a href="/" class="service-link">← Back to Home</a>
		</div>
	</main>
</BaseLayout>

<style>
	.tag-header {
		margin-bottom: 24px;
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: 24px;
		font-weight: 500;
	}

	.post-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.post-item {
		display: flex;
		align-items: baseline;
		gap: 16px;
	}

	.post-date {
		font-size: 12px;
		opacity: 0.5;
		flex-shrink: 0;
		width: 90px;
	}

	.post-title-and-tags {
		display: flex;
		align-items: baseline;
		gap: 12px;
		flex-wrap: wrap;
	}

	.post-tags {
		display: flex;
		gap: 8px;
		font-size: 11px;
		opacity: 0.5;
	}

	.tag-link {
		color: inherit;
		text-decoration: none;
	}

	.tag-link:hover,
	.tag-link.active {
		text-decoration: underline;
	}

	.tag-link.active {
		font-weight: bold;
		opacity: 0.8;
	}

	.post-link {
		color: inherit;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 4px;
		text-decoration-color: var(--underline-color);
		transition: text-decoration-color 0.2s ease;
	}

	.post-link:hover {
		text-decoration-color: var(--underline-hover);
	}

	.back-home {
		margin-top: 32px;
		font-size: 13px;
	}

	@media (max-width: 768px) {
		.post-item {
			flex-direction: column;
			gap: 4px;
		}

		.post-date {
			width: auto;
		}
	}
</style>
