---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import profile from '../data/profile.json';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	audioUrl?: string;
}

const { title, description, pubDate, audioUrl } = Astro.props;

const blogSeo = {
	og: {
		...profile.seo.og,
		title: `${title} | ${profile.header.logo}`,
		description: description,
	},
	twitter: {
		...profile.seo.twitter,
		title: `${title} | ${profile.header.logo}`,
		description: description,
	}
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout title={`${title} | ${profile.header.logo}`} description={description} seo={blogSeo}>
	<Header logo={profile.header.logo} />

	<main>
		<article class="blog-post">
			<header class="post-header">
				<h1 class="post-title">{title}</h1>
				<div class="post-meta">
					<time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
				</div>
			</header>

			<hr class="post-divider" />

			{audioUrl && <AudioPlayer audioUrl={audioUrl} title={title} />}

			<div class="post-content">
				<slot />
			</div>
		</article>

		<div class="back-home">
			<a href="/" class="service-link">← Back to Home</a>
		</div>

		<!-- Lightbox Overlay -->
		<div id="image-lightbox" class="lightbox">
			<img id="lightbox-img" src="" alt="Lightbox image" />
		</div>
	</main>
</BaseLayout>

<style>
	.blog-post {
		max-width: 650px;
		margin-bottom: 40px;
	}

	.post-header {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin-bottom: 16px;
	}

	.post-title {
		font-family: var(--font-serif);
		font-size: 28px;
		font-weight: 500;
		line-height: 1.3;
	}

	.post-date {
		font-size: 13px;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 13px;
		opacity: 0.6;
	}


	.post-divider {
		border: 0;
		border-top: 1px solid var(--border-color, rgba(0, 0, 0, 0.08));
		margin: 16px 0 24px 0;
	}

	.post-content {
		font-family: var(--font-mono);
		font-size: 14px;
		line-height: 1.7;
	}

	.post-content :global(p) {
		margin-bottom: 16px;
	}

	.post-content :global(img) {
		max-width: 100%;
		height: auto;
		display: block;
		margin: 24px auto;
		border-radius: 4px;
		border: 1px solid var(--border-color, rgba(0, 0, 0, 0.08));
		cursor: zoom-in;
		transition: transform 0.2s ease-in-out;
	}

	.post-content :global(img:hover) {
		transform: scale(1.008);
	}

	/* Lightbox styling */
	.lightbox {
		display: none;
		position: fixed;
		z-index: 1000;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(245, 244, 239, 0.98); /* match background-color */
		justify-content: center;
		align-items: center;
		cursor: zoom-out;
		opacity: 0;
		transition: opacity 0.2s ease-in-out;
	}

	.lightbox.active {
		display: flex;
		opacity: 1;
	}

	.lightbox img {
		max-width: 90vw;
		max-height: 90vh;
		object-fit: contain;
		border-radius: 4px;
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
		border: 1px solid var(--border-color, rgba(0, 0, 0, 0.08));
	}

	.post-content :global(h2),
	.post-content :global(h3) {
		font-family: var(--font-serif);
		margin-top: 24px;
		margin-bottom: 12px;
		font-weight: 500;
	}

	.post-content :global(h2) {
		font-size: 20px;
	}

	.post-content :global(h3) {
		font-size: 17px;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin-left: 20px;
		margin-bottom: 16px;
	}

	.post-content :global(li) {
		margin-bottom: 6px;
	}

	.post-content :global(strong) {
		font-weight: 600;
	}

	.back-home {
		margin-top: 24px;
		font-size: 13px;
	}

	/* Code Snippet Styles */
	.post-content :global(.code-block-wrapper) {
		position: relative;
		margin: 28px 0;
		border-radius: 8px;
		background-color: #1f2428;
		border: 1px solid #30363d;
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
		overflow: hidden;
	}

	.post-content :global(.code-block-header) {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 8px 16px;
		background-color: #1b1f23;
		border-bottom: 1px solid #30363d;
		font-family: var(--font-mono);
		font-size: 11px;
		color: #8b949e;
	}

	.post-content :global(.code-block-lang) {
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.8px;
		font-size: 10px;
	}

	.post-content :global(.copy-button) {
		background: transparent;
		border: 1px solid rgba(240, 246, 252, 0.1);
		border-radius: 4px;
		color: #c9d1d9;
		padding: 4px 10px;
		font-size: 11px;
		font-family: var(--font-mono);
		cursor: pointer;
		transition: all 0.15s ease-in-out;
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.post-content :global(.copy-button:hover) {
		background-color: rgba(240, 246, 252, 0.1);
		border-color: rgba(240, 246, 252, 0.25);
		color: #ffffff;
	}

	.post-content :global(.copy-button.copied) {
		color: #3fb950;
		border-color: #3fb950;
		background-color: rgba(63, 185, 80, 0.1);
	}

	.post-content :global(pre) {
		margin: 0 !important;
		padding: 18px 20px !important;
		background-color: #24292e !important;
		font-family: var(--font-mono);
		font-size: 13px !important;
		line-height: 1.6;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.post-content :global(pre code) {
		background: none !important;
		padding: 0 !important;
		border: none !important;
		font-size: inherit !important;
		color: inherit !important;
		border-radius: 0 !important;
	}

	/* Inline Code Snippets */
	.post-content :global(:not(pre) > code) {
		background-color: rgba(0, 0, 0, 0.05);
		color: #24292e;
		padding: 3px 6px;
		border-radius: 4px;
		font-size: 13px;
		font-family: var(--font-mono);
		border: 1px solid rgba(0, 0, 0, 0.06);
		word-break: break-word;
	}
</style>

<script>
	const postImages = document.querySelectorAll('.post-content img');
	const lightbox = document.getElementById('image-lightbox');
	const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

	if (lightbox && lightboxImg) {
		postImages.forEach((img) => {
			img.addEventListener('click', () => {
				const src = img.getAttribute('src');
				const alt = img.getAttribute('alt') || 'Blog post image';
				if (src) {
					lightboxImg.src = src;
					lightboxImg.alt = alt;
					lightbox.classList.add('active');
					document.body.style.overflow = 'hidden';
				}
			});
		});

		lightbox.addEventListener('click', () => {
			lightbox.classList.remove('active');
			document.body.style.overflow = '';
		});
	}

	// Code snippet enhancements: wrappers, headers, copy buttons
	const codeBlocks = document.querySelectorAll('.post-content pre');
	codeBlocks.forEach((pre) => {
		const lang = pre.getAttribute('data-language') || 'code';
		
		const wrapper = document.createElement('div');
		wrapper.className = 'code-block-wrapper';
		
		const header = document.createElement('div');
		header.className = 'code-block-header';
		
		const langLabel = document.createElement('span');
		langLabel.className = 'code-block-lang';
		langLabel.textContent = lang;
		
		const copyBtn = document.createElement('button');
		copyBtn.className = 'copy-button';
		copyBtn.type = 'button';
		copyBtn.textContent = 'Copy';
		
		header.appendChild(langLabel);
		header.appendChild(copyBtn);
		
		if (pre.parentNode) {
			pre.parentNode.insertBefore(wrapper, pre);
			wrapper.appendChild(pre);
			wrapper.insertBefore(header, pre);
		}
		
		copyBtn.addEventListener('click', async () => {
			const codeText = pre.querySelector('code')?.textContent || pre.textContent || '';
			try {
				await navigator.clipboard.writeText(codeText);
				copyBtn.textContent = 'Copied!';
				copyBtn.classList.add('copied');
				setTimeout(() => {
					copyBtn.textContent = 'Copy';
					copyBtn.classList.remove('copied');
				}, 2000);
			} catch (err) {
				console.error('Failed to copy text: ', err);
				copyBtn.textContent = 'Error';
			}
		});
	});
</script>
